# ============================================================================
# SUPABASE - Database & Authentication
# ============================================================================
# Create project at: https://supabase.com
# Get credentials from: Settings → API

# Your Supabase project URL (looks like: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (KEEP SECRET - server-side only, never in browser)
# Get from: Settings → API → Service role secret
SUPABASE_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Project ID (used for some operations)
SUPABASE_PROJECT_ID=your-project-id


# ============================================================================
# EMAIL & NEWSLETTERS (Resend)
# ============================================================================
# Create account at: https://resend.com
# Get key from: Settings → API Keys

# Resend API key for sending emails
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email address to send from (must be verified in Resend)
FROM_EMAIL=hello@orvnlabs.com


# ============================================================================
# INTEGRATIONS (Optional)
# ============================================================================

# Google Sheets webhook (for logging newsletter signups)
# Create via: https://script.google.com (Google Apps Script)
SHEET_WEBHOOK_URL=https://script.google.com/macros/s/xxxxx/usercontent

# Slack webhook (for notifications when people sign up)
# Create via: Slack workspace → Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX


# ============================================================================
# OPTIONAL: Analytics & Monitoring
# ============================================================================

# Vercel Analytics (if using Vercel)
VERCEL_ENV=production
VERCEL_GIT_COMMIT_SHA=xxxxx

# Sentry error tracking (optional)
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/12345


# ============================================================================
# DATABASE (if using separate DB, not Supabase)
# ============================================================================
# Only needed if NOT using Supabase

# DATABASE_URL=postgresql://user:password@localhost:5432/orvn_blog


# ============================================================================
# NOTES
# ============================================================================
#
# FRONTEND SAFE: Variables prefixed with VITE_ are safe to expose in the browser
# - VITE_SUPABASE_URL ✅ Safe
# - VITE_SUPABASE_ANON_KEY ✅ Safe
#
# SERVER ONLY (Never expose):
# - SUPABASE_API_KEY ⚠️ Keep secret
# - RESEND_API_KEY ⚠️ Keep secret
# - SLACK_WEBHOOK_URL ⚠️ Keep secret
# - SHEET_WEBHOOK_URL ⚠️ Keep secret
#
# USAGE:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values in .env.local
# 3. NEVER commit .env.local to git
# 4. For Vercel: add env vars in Project Settings → Environment Variables
#
# ============================================================================
