# ORVN Labs website — environment variables
# Copy this file to .env.local for local development. Set the same vars in Vercel for prod.

# ───────────────────────── Public (browser) ─────────────────────────
# VITE_-prefixed vars are bundled into the client. Never put secrets here.

# URL of the PAS app/dashboard. Used by every "Login", "Open PAS Control Room",
# and "Test PAS" CTA on the site. Falls back to https://app.orvnlabs.com if unset.
VITE_PAS_APP_URL=https://app.orvnlabs.com

# ───────────────────────── Server-only secrets ─────────────────────────
# These are read by serverless functions in /api. NEVER prefix with VITE_.

# Resend API key — used by /api/calculator-email and /api/newsletter to send mail.
# Get one at https://resend.com. Rotate immediately if exposed.
RESEND_API_KEY=

# Google Apps Script webhook for logging calculator submissions to a Sheet.
# Optional — leave blank to disable.
SHEET_WEBHOOK_URL=

# Slack incoming webhook for new-lead alerts. Optional.
SLACK_WEBHOOK_URL=

# "From" address used by Resend. Must be a verified sender in Resend.
FROM_EMAIL="Daniel @ ORVN Labs <daniel@orvnlabs.com>"
